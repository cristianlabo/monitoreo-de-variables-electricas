
API_HOST=0.0.0.0
API_PORT=3000

# HTTPS con certificado autofirmado (producción en Oracle Cloud)
API_SSL_ENABLED=false
API_SSL_KEY_PATH=./certs/api-server.key
API_SSL_CERT_PATH=./certs/api-server.crt

# Orígenes permitidos para CORS (separados por coma)
# CORS_ORIGINS=https://tu-app.vercel.app,http://localhost:3001

MQTT_USERNAME=alumno
MQTT_PASSWORD=alumno
MQTT_HOST=www.daiot.com.ar
MQTT_PORT=8883

DB_MONGO_USERNAME=mongo_user
DB_MONGO_PASSWORD=mongo_user_psw
DB_MONGO_DBNAME=mongo_db_name
DB_MONGO_HOST=mongo_db_host
DB_MONGO_PORT=27017

DB_MYSQL_USERNAME=root
DB_MYSQL_PASSWORD=root
DB_MYSQL_DBNAME=test
DB_MYSQL_HOST=localhost
DB_MYSQL_PORT=3306

ROUTER_PATH=/home/backend/routers
ENVIRONMENT=dev
